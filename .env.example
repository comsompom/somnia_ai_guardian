# Somnia / EVM endpoint settings
# Devnet/Testnet default:
RPC_HTTP_URL=https://dream-rpc.somnia.network
# Optional; listener currently uses HTTP polling by default.
RPC_WSS_URL=
CHAIN_ID=50312
# Mainnet option:
# RPC_HTTP_URL=https://api.infra.mainnet.somnia.network
# CHAIN_ID=5031

# Deployer / agent wallet
PRIVATE_KEY=replace_with_private_key_hex

# Deployed contract address (filled after deploy)
VAULT_ADDRESS=0xF27dcfE71FDa832cfc0777235D9eCaCeDFD768F8

# AI providers (optional; leave empty to use rule fallback)
OPENAI_API_KEY=
OPENAI_MODELS=gpt-4o-mini,gpt-4.1-mini,gpt-4.1

GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash-preview-05-20,gemini-2.0-flash,gemini-2.5-pro,gemini-2.5-pro-preview-06-05,gemini-3-pro-preview
